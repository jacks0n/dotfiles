" Settings that should be set AFTER plugins load.
" Examples: colorscheme, font, plugin-specific overrides.

" https://github.com/benwainwright/fzf-project
let g:fzfSwitchProjectWorkspaces = ['~/Code']
let g:telescope_project_workspaces = ['~/Code', '~/.dotfiles']

" https://github.com/heavenshell/vim-jsdoc
let g:jsdoc_lehre_path = trim(system('brew --prefix')) . '/bin/lehre'

let $NVIM_PYTHON_LOG_FILE = $HOME . '/Desktop/nvim-python.log'
let $PATH = trim(system('brew --prefix')) . '/bin:' . $PATH

" Set `colorscheme` and `guifont` only on startup.
if has('vim_starting')
  if has('nvim')
    colorscheme nightfox
    " colorscheme tokyonight-moon
    " colorscheme catppuccin-mocha

    " colorscheme embark
    " colorscheme duskfox
    " colorscheme kanagawa
    " colorscheme pinkmare
    " let g:enfocado_style = 'nature'
    " colorscheme enfocado

    " colorscheme OceanicNext
    " colorscheme gruvbox

    " colorscheme hybrid
    " colorscheme badwolf
    " colorscheme rose-pine
    " colorscheme monokain
  else
    colorscheme gruvbox
  endif
  set background=dark
  if has('gui') || exists('g:neovide')
    " set guifont=FantasqueSansMono\ Nerd\ Font:h19
    " set guifont=Hack\ Nerd\ Font:h19
    " set guifont=JetBrainsMono\ Nerd\ Font:h19
    " set guifont=DroidSansMono\ Nerd\ Font:h17
    " set guifont=Inconsolata\ Nerd\ Font:h22
    set guifont=UbuntuMono\ Nerd\ Font:h22
    " set guifont=FiraMono\ Nerd\ Font\ Mono:h19:b3
    " set guifont=mononoki\ Nerd\ Font:h20
    " TBA install
    " set guifont=LiterationMono\ Nerd\ Font:h18
    " set guifont=FuraMono\ Nerd\ Font:h17
    " set guifont=SFMono\ Nerd\ Font:h18
  endif

  if exists('g:neovide')
    let g:neovide_remember_window_size = v:true
    " @see https://neovide.dev/configuration.html#cursor-particles
    let g:neovide_cursor_vfx_mode = 'railgun'
  endif
endif

" Neovim Python 3 binary path.
if has('nvim')
  let g:python3_host_prog = trim(system('brew --prefix')) . '/bin/python3'
endif
